<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Auxiliador Financeiro</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
      background: #f4f6f9;
    }
    h1 {
      text-align: center;
      color: #2c3e50;
    }
    .container {
      display: flex;
      justify-content: space-around;
      margin-top: 20px;
    }
    .form-section, .dashboard {
      background: white;
      padding: 20px;
      border-radius: 8px;
      width: 45%;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    input, select, button {
      margin: 5px 0;
      padding: 8px;
      width: 100%;
    }
    button {
      background: #27ae60;
      color: white;
      border: none;
      cursor: pointer;
    }
    button:hover {
      background: #219150;
    }
  </style>
</head>
<body>
  <h1>Auxiliador Financeiro</h1>

  <div class="container">
    <!-- Formulário de registro -->
    <div class="form-section">
      <h2>Registrar Transação</h2>
      <form id="transactionForm">
        <input type="text" id="descricao" placeholder="Descrição" required>
        <input type="number" id="valor" placeholder="Valor" required>
        <select id="tipo">
          <option value="receita">Receita</option>
          <option value="despesa">Despesa</option>
        </select>
        <button type="submit">Adicionar</button>
      </form>

      <h2>Definir Meta Financeira</h2>
      <input type="number" id="meta" placeholder="Meta (R$)">
      <button onclick="definirMeta()">Salvar Meta</button>
      <p id="metaInfo"></p>
    </div>

    <!-- Dashboard -->
    <div class="dashboard">
      <h2>Dashboard Financeiro</h2>
      <canvas id="financeChart"></canvas>
      <p id="saldoInfo"></p>
    </div>
  </div>

  <script>
    let receitas = 0;
    let despesas = 0;
    let meta = 0;

    const ctx = document.getElementById('financeChart').getContext('2d');
    const financeChart = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['Receitas', 'Despesas'],
        datasets: [{
          data: [receitas, despesas],
          backgroundColor: ['#27ae60', '#e74c3c']
        }]
      }
    });

    document.getElementById('transactionForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const valor = parseFloat(document.getElementById('valor').value);
      const tipo = document.getElementById('tipo').value;

      if (tipo === 'receita') {
        receitas += valor;
      } else {
        despesas += valor;
      }

      atualizarDashboard();
    });

    function atualizarDashboard() {
      financeChart.data.datasets[0].data = [receitas, despesas];
      financeChart.update();

      const saldo = receitas - despesas;
      document.getElementById('saldoInfo').innerText = `Saldo atual: R$ ${saldo.toFixed(2)}`;

      if (meta > 0) {
        document.getElementById('metaInfo').innerText = 
          saldo >= meta ? "🎉 Meta atingida!" : `Meta: R$ ${meta.toFixed(2)} (Faltam R$ ${(meta - saldo).toFixed(2)})`;
      }
    }

    function definirMeta() {
      meta = parseFloat(document.getElementById('meta').value);
      atualizarDashboard();
    }
  </script>
</body>
</html>
